# ── API ───────────────────────────────────────────────────────────────────────
# Local dev: http://localhost:5000
# Production: your Render URL e.g. https://pride-auto-api.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:5000

# ── Google Analytics ─────────────────────────────────────────────────────────
# Get from: https://analytics.google.com
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── Google Maps Embed ─────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → Maps Embed API
NEXT_PUBLIC_MAPS_KEY=your_google_maps_key

# ── Tawk.to Live Chat ────────────────────────────────────────────────────────
# Get from: https://tawk.to → Admin → Chat Widget → Direct Chat Link
NEXT_PUBLIC_TAWKTO_ID=your_tawkto_widget_id
